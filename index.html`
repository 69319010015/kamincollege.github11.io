                { name: "GR Yaris", desc: "Rally-bred performance in a compact, aggressive package built for the track.", img: "toyota,yaris,rally" },
                { name: "Land Cruiser", desc: "The ultimate symbol of rugged durability and luxury off-road capability.", img: "toyota,land-cruiser,offroad" },
                { name: "RAV4", desc: "A versatile, modern compact SUV designed for every adventure.", img: "toyota,rav4,suv" },
                { name: "Camry", desc: "The gold standard of reliability, elegance, and efficiency in every mile.", img: "toyota,camry,sedan" },
                { name: "Prius", desc: "Pioneering the future of hybrid efficiency with a bold, modern aesthetic.", img: "toyota,prius,hybrid" },
                { name: "Tacoma", desc: "A powerhouse of a truck, engineered for the toughest jobs and toughest trails.", img: "toyota,tacoma,truck" },
                { name: "Corolla Cross", desc: "A smart, agile crossover that blends practicality with a spirited drive.", img: "toyota,corolla-cross,crossover" },
                { name: "Tundra", desc: "Massive power meets premium luxury in Toyota's most capable pickup.", img: "toyota,tundra,pickup" },
                { name: "Century", desc: "The pinnacle of Japanese automotive luxury, crafted for the most discerning.", img: "toyota,century,luxury" }
            ],
            Honda: [
                { name: "Civic Type R", desc: "A track-focused masterpiece that redefines the hot-hatch experience.", img: "honda,civic-type-r,sports" },
                { name: "Accord", desc: "Sleek, sophisticated, and effortlessly smooth for the modern professional.", img: "honda,accord,sedan" },
                { name: "NSX", desc: "Hybrid precision meets supercar performance in a breathtaking silhouette.", img: "honda,nsx,supercar" },
                { name: "CR-V", desc: "The perfect balance of family utility and innovative design.", img: "honda,crv,suv" },
                { name: "Pilot", desc: "Spacious, powerful, and ready for the whole family to travel in luxury.", img: "honda,pilot,suv" },
                { name: "HR-V", desc: "A nimble and stylish urban crossover that fits perfectly in the city.", img: "honda,hrv,crossover" },
                { name: "Honda e", desc: "A futuristic, all-electric urban mobility solution with cutting-edge tech.", img: "honda,electric,ev" },
                { name: "Prelude Concept", desc: "A bold glimpse into the future of Honda's sports coupe heritage.", img: "honda,concept,car" },
                { name: "Ridgeline", desc: "Unexpected versatility and comfort in a unique, capable pickup.", img: "honda,ridgeline,truck" },
                { name: "Odyssey", desc: "The ultimate family cruiser, blending space with high-end convenience.", img: "honda,odyssey,minivan" }
            ],
            Tesla: [
                { name: "Model S Plaid", desc: "Blindingly fast acceleration paired with unmatched luxury and range.", img: "tesla,model-s,electric" },
                { name: "Model 3", desc: "The most accessible entry into the world of high-performance electric driving.", img: "tesla,model-3,ev" },
                { name: "Model X", desc: "Defining the SUV of the future with iconic Falcon Wing doors.", img: "tesla,model-x,electric-suv" },
                { name: "Model Y", desc: "A versatile electric crossover that blends efficiency with spacious utility.", img: "tesla,model-y,ev" },
                { name: "Cybertruck", desc: "A futuristic exoskeleton on wheels, redefining the utility vehicle.", img: "tesla,cybertruck,futuristic" },
                { name: "Roadster 2.0", desc: "The ultimate expression of electric speed and exhilarating design.", img: "tesla,roadster,supercar" },
                { name: "Semi", desc: "Transforming the logistics industry with zero-emission heavy hauling.", img: "tesla,semi,truck" },
                { name: "Model 3 Highland", desc: "Refined aesthetics and superior comfort for a more polished ride.", img: "tesla,model-3,modern" },
                { name: "Model Y Juniper", desc: "The next evolution of the most popular electric crossover on Earth.", img: "tesla,model-y,updated" },
                { name: "Cyberbeast", desc: "Unleashing raw, electric power in the most aggressive Tesla form yet.", img: "tesla,cyberbeast,power" }
            ],
            Nissan: [
                { name: "GT-R Nismo", desc: "The 'Godzilla' of performance, refined for absolute track dominance.", img: "nissan,gtr,nismo" },
                { name: "Z Performance", desc: "A modern homage to a legend, combining retro style with cutting-edge power.", img: "nissan,z-car,sports" },
                { name: "Ariya", desc: "Nissan's vision of the electric future, blending Zen and high-tech design.", img: "nissan,ariya,electric" },
                { name: "Rogue", desc: "An intelligent, adaptable SUV designed for every day and every journey.", img: "nissan,rogue,suv" },
                { name: "Pathfinder", desc: "Bold, capable, and ready to tackle the road and the wild alike.", img: "nissan,pathfinder,suv" },
                { name: "Patrol", desc: "A desert-conquering giant with uncompromised luxury and power.", img: "nissan,patrol,offroad" },
                { name: "Leaf", desc: "One of the world's most trusted electric vehicles, leading the charge.", img: "nissan,leaf,ev" },
                { name: "Frontier", desc: "Tough, reliable, and built for those who don't stop until the job is done.", img: "nissan,frontier,truck" },
                { name: "Sentra", desc: "Sophisticated design meets effortless efficiency in a compact sedan.", img: "nissan,sentra,sedan" },
                { name: "Qashqai", desc: "The original crossover, blending agility with a premium urban feel.", img: "nissan,qashqai,crossover" }
            ],
            BYD: [
                { name: "Seal", desc: "A stunning electric sedan that blends aerodynamic grace with raw power.", img: "byd,seal,electric" },
                { name: "Han", desc: "Flagship luxury meets innovative electric power in a commanding presence.", img: "byd,han,luxury-ev" },
                { name: "Tang", desc: "A spacious, high-tech electric SUV designed for the modern family.", img: "byd,tang,suv-ev" },
                { name: "Atto 3", desc: "Bold design and surprising performance in a smart, electric crossover.", img: "byd,atto3,ev" },
                { name: "Dolphin", desc: "Playful, efficient, and designed for the vibrant rhythm of the city.", img: "byd,dolphin,city-ev" },
                { name: "Sealion 7", desc: "A high-performance electric SUV that challenges the boundaries of style.", img: "byd,sealion,ev" },
                { name: "Shark 6", desc: "BYD's entry into the electric pickup world, blending power and precision.", img: "byd,shark,truck-ev" },
                { name: "Seagull", desc: "Compact efficiency and surprising value in a modern electric hatch.", img: "byd,seagull,ev" },
                { name: "Yangwang U8", desc: "A luxury behemoth capable of amphibious travel and extreme off-roading.", img: "byd,yangwang-u8,luxury" },
                { name: "Yangwang U9", desc: "A breathtaking electric supercar designed for absolute peak performance.", img: "byd,yangwang-u9,supercar" }
            ]
        };

        const state = {
            activeBrand: 'Toyota',
            currentIndex: 0
        };

        const brandNav = document.getElementById('brandNav');
        const carouselStage = document.getElementById('carouselStage');
        const carImg = document.getElementById('carImg');
        const modelName = document.getElementById('modelName');
        const modelDesc = document.getElementById('modelDesc');
        const carOverlay = document.getElementById('carOverlay');
        const prevBtn = document.getElementById('prevBtn');
        const nextBtn = document.getElementById('nextBtn');

        function init() {
            // Populate Brand Navigation
            Object.keys(CAR_DATA).forEach(brand => {
                const btn = document.createElement('button');
                btn.className = `brand-btn ${brand === state.activeBrand ? 'active' : ''}`;
                btn.innerText = brand;
                btn.onclick = () => handleBrandChange(brand);
                brandNav.appendChild(btn);
            });

            updateUI();
        }

        function updateUI() {
            const brandCars = CAR_DATA[state.activeBrand];
            const car = brandCars[state.currentIndex];

            // Transition Effect: Fade out stage and overlay
            carouselStage.style.opacity = '0';
            carouselStage.style.transform = 'scale(1.02)';
            carOverlay.classList.add('fade-up');

            setTimeout(() => {
                // Use a more reliable image placeholder service
                // Using loremflickr for keyword-based high quality cars
                const imgUrl = `https://loremflickr.com/1200/800/car,${car.img.split(',')[0]}`;
                carImg.src = imgUrl;
                modelName.innerText = car.name;
                modelDesc.innerText = car.desc;

                // Fade back in
                carouselStage.style.opacity = '1';
                carouselStage.style.transform = 'scale(1)';
                carOverlay.classList.remove('fade-up');
            }, 300);
        }

        function handleBrandChange(brand) {
            state.activeBrand = brand;
            state.currentIndex = 0;

            // Update button active states
            document.querySelectorAll('.brand-btn').forEach(btn => {
                btn.classList.toggle('active', btn.innerText === brand);
            });

            updateUI();
        }

        function handleNext() {
            state.currentIndex = (state.currentIndex + 1) % 10;
            updateUI();
        }

        function handlePrev() {
            state.currentIndex = (state.currentIndex - 1 + 10) % 10;
            updateUI();
        }

        prevBtn.onclick = handlePrev;
        nextBtn.onclick = handleNext;

        init();
    </script>
</body>
</html>
